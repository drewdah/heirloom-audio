# .env.example — copy to .env and fill in your values

# ── App ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# 5. Enable the Google Drive API in your project
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Database ──────────────────────────────────────────────
DATABASE_URL=file:/data/db/heirloom.db

# ── Redis ─────────────────────────────────────────────────
# Full docker compose:  redis://redis:6379
# Local dev (hybrid):   redis://localhost:6379
REDIS_URL=redis://redis:6379

# ── Whisper worker ────────────────────────────────────────
# Model size: tiny, base, small (default), medium, large
WHISPER_MODEL=small
# Full docker compose:  http://app:3000  (default, no need to set)
# Local dev (hybrid):   http://host.docker.internal:3000
APP_URL=http://app:3000

# ── Access Control ────────────────────────────────────────
# Comma-separated list of emails allowed to log in.
# Leave empty to allow any Google account.
ALLOWED_EMAILS=dad@gmail.com,you@gmail.com
